---
import { getLangFromUrl, type Language } from '~/i18n/utils';
import { defaultLanguage } from '~/i18n/ui';
import { languages } from '~/i18n/ui';

const lang = getLangFromUrl(Astro.url);
const path = Astro.url.pathname;
const homeHref = `/${lang}/`;
const archiveHref = `/${lang}/archive/`;
const tagsHref = `/${lang}/tags/`;
const aboutHref = `/${lang}/about/`;

const navItems: { label: string; href: string }[] = [
  { label: lang === 'zh' ? '归档' : 'Archive', href: archiveHref },
  { label: lang === 'zh' ? '标签' : 'Tags', href: tagsHref },
  { label: lang === 'zh' ? '关于' : 'About', href: aboutHref },
];

function isCurrent(href: string): boolean {
  if (href === homeHref) return path === homeHref || path === `/${lang}` || path === `/${lang}/`;
  return path.startsWith(href);
}

const altLang = lang === 'zh' ? 'en' : 'zh';
const stripped = path.replace(/^\/(zh|en)(?=\/|$)/, '') || '/';
const tail = stripped === '/' ? '/' : `${stripped.startsWith('/') ? '' : '/'}${stripped}`;
const langSwitchHref = `/${altLang}${tail}`;
const langSwitchLabel = languages[altLang];
---
<header class="site-header">
  <div class="container site-header__inner">
    <a id="__hdr_home" href={homeHref} class="site-header__brand">yeye</a>
    <nav class="site-header__nav" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={item.href} class="nav-link" aria-current={isCurrent(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
      <a
        href={langSwitchHref}
        class="lang-switch"
        aria-label={`Switch language to ${langSwitchLabel}`}
        title={`Switch language to ${langSwitchLabel}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <span>{langSwitchLabel}</span>
      </a>
      <button
        type="button"
        class="icon-btn"
        data-theme-toggle
        aria-label={lang === 'zh' ? '切换主题' : 'Toggle theme'}
        title={lang === 'zh' ? '切换主题' : 'Toggle theme'}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          data-theme-icon
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- #region agent debug -->
<script is:inline>
(function () {
  var lsKey = '__hdr_debug';
  try {
    var arr = JSON.parse(localStorage.getItem(lsKey) || '[]');
    arr.push({ t: Date.now(), pathname: location.pathname, action: 'load' });
    if (arr.length > 40) arr = arr.slice(-40);
    localStorage.setItem(lsKey, JSON.stringify(arr));
  } catch (_) {}
  var box = document.createElement('div');
  box.id = '__hdr_box';
  box.style.cssText = 'position:fixed;bottom:8px;left:8px;max-width:400px;background:rgba(10,10,15,.95);color:#d4f7d4;font:11px/1.55 monospace;padding:8px 10px;border-radius:6px;z-index:2147483647;white-space:pre-wrap;word-break:break-all;box-shadow:0 2px 16px rgba(0,0,0,.6);max-height:300px;overflow-y:auto';
  function render() {
    var data = JSON.parse(localStorage.getItem(lsKey) || '[]');
    box.textContent = JSON.stringify(data.slice(-8), null, 2);
  }
  render();
  document.querySelectorAll('a[id]').forEach(function (a) {
    a.addEventListener('mouseenter', function () {
      try {
        var arr2 = JSON.parse(localStorage.getItem(lsKey) || '[]');
        arr2.push({ t: Date.now(), pathname: location.pathname, action: 'hover:' + a.id, href: a.getAttribute('href'), text: a.textContent.trim() });
        if (arr2.length > 40) arr2 = arr2.slice(-40);
        localStorage.setItem(lsKey, JSON.stringify(arr2));
        render();
      } catch (_) {}
    });
  });
  box.style.display = 'none';
  box.title = 'Click to toggle debug box';
  box.style.cursor = 'pointer';
  box.addEventListener('click', function () { box.style.display = box.style.display === 'none' ? 'block' : 'none'; });
  document.body.appendChild(box);
  console.log('[HDR DEBUG]', JSON.parse(localStorage.getItem(lsKey) || '[]'));
})();
</script>
<!-- #endregion -->
