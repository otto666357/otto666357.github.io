---
import { getLangFromUrl, getAlternateLanguage, getLocalizedPath } from '~/i18n/utils';
import { defaultLanguage } from '~/i18n/ui';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  pubDate,
  updatedDate,
  tags = [],
  author = 'otto666357',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const alternateLang = getAlternateLanguage(lang);
const alternatePath = getLocalizedPath(Astro.url.pathname, alternateLang);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site).toString();

const siteTitle = 'yeye';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  headline: title,
  description,
  url: canonicalURL.toString(),
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en-US',
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Person', name: author },
};

if (type === 'article') {
  if (pubDate) jsonLd.datePublished = pubDate.toISOString();
  if (updatedDate) jsonLd.dateModified = updatedDate.toISOString();
  if (tags.length > 0) jsonLd.keywords = tags.join(', ');
}
---
<!-- Charset & viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Title & description -->
<title>{fullTitle}</title>
<meta name="description" content={description} />

<!-- Theme color reflects current theme -->
<meta name="theme-color" content={lang === 'zh' ? '#fafaf9' : '#0a0a0a'} media="(prefers-color-scheme: light)" />
<meta name="theme-color" content={lang === 'zh' ? '#0a0a0a' : '#fafaf9'} media="(prefers-color-scheme: dark)" />

<!-- Canonical & alternate languages -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang={lang === 'zh' ? 'zh-CN' : 'en-US'} href={canonicalURL} />
<link rel="alternate" hreflang={alternateLang === 'zh' ? 'zh-CN' : 'en-US'} href={new URL(alternatePath, Astro.site)} />
<link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath(Astro.url.pathname, defaultLanguage), Astro.site)} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={`${siteTitle} (${lang})`} href={`/${lang}/rss.xml`} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{tags.map((t) => <meta property="article:tag" content={t} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Theme bootstrap (FOUC-free) -->
<script is:inline>
  (function () {
    try {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    } catch (_) {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>
