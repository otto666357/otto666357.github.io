---
import { getLangFromUrl, getAlternateLanguage, getLocalizedPath } from '~/i18n/utils';
import { defaultLanguage } from '~/i18n/ui';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  pubDate,
  updatedDate,
  tags = [],
  author = 'otto666357',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const alternateLang = getAlternateLanguage(lang);
const alternatePath = getLocalizedPath(Astro.url.pathname, alternateLang);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site).toString();

const siteTitle = 'yeye';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  headline: title,
  description,
  url: canonicalURL.toString(),
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en-US',
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Person', name: author },
};

if (type === 'article') {
  if (pubDate) jsonLd.datePublished = pubDate.toISOString();
  if (updatedDate) jsonLd.dateModified = updatedDate.toISOString();
  if (tags.length > 0) jsonLd.keywords = tags.join(', ');
}
---
<!-- Charset & viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Title & description -->
<title>{fullTitle}</title>
<meta name="description" content={description} />

<!-- Theme color reflects current theme -->
<meta name="theme-color" content={lang === 'zh' ? '#fafaf9' : '#0a0a0a'} media="(prefers-color-scheme: light)" />
<meta name="theme-color" content={lang === 'zh' ? '#0a0a0a' : '#fafaf9'} media="(prefers-color-scheme: dark)" />

<!-- Canonical & alternate languages -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang={lang === 'zh' ? 'zh-CN' : 'en-US'} href={canonicalURL} />
<link rel="alternate" hreflang={alternateLang === 'zh' ? 'zh-CN' : 'en-US'} href={new URL(alternatePath, Astro.site)} />
<link rel="alternate" hreflang="x-default" href={new URL(getLocalizedPath(Astro.url.pathname, defaultLanguage), Astro.site)} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={`${siteTitle} (${lang})`} href={`/${lang}/rss.xml`} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
{type === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{tags.map((t) => <meta property="article:tag" content={t} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Theme bootstrap (FOUC-free) -->
<script is:inline>
  (function () {
    try {
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = stored || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    } catch (_) {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>

<!-- #region agent log (hypothesis: VT cross-language navigation behaviour) -->
<script is:inline>
  (function () {
    var KEY = '__dbg_nav_log';
    var LS_KEY = '__dbg_nav_ls';
    function append(rec) {
      try {
        var arr = JSON.parse(sessionStorage.getItem(KEY) || '[]');
        arr.push(rec);
        sessionStorage.setItem(KEY, JSON.stringify(arr));
      } catch (_) {}
      try {
        var ls = JSON.parse(localStorage.getItem(LS_KEY) || '[]');
        ls.push(rec);
        if (ls.length > 80) ls = ls.slice(-80);
        localStorage.setItem(LS_KEY, JSON.stringify(ls));
      } catch (_) {}
    }
    function ensureBox() {
      var box = document.getElementById('__dbg_nav_box');
      if (box) return box;
      box = document.createElement('div');
      box.id = '__dbg_nav_box';
      box.style.cssText =
        'position:fixed;right:8px;bottom:8px;max-width:min(92vw,560px);max-height:55vh;overflow:auto;' +
        'background:rgba(15,15,20,.92);color:#eaeaea;font:12px/1.45 ui-monospace,Consolas,monospace;' +
        'padding:8px 10px;border-radius:6px;z-index:2147483647;white-space:pre-wrap;word-break:break-all;' +
        'box-shadow:0 2px 12px rgba(0,0,0,.4)';
      document.body.appendChild(box);
      return box;
    }
    function render() {
      var ls = [];
      try { ls = JSON.parse(localStorage.getItem(LS_KEY) || '[]') || []; } catch (_) {}
      var box = ensureBox();
      box.textContent = ls
        .map(function (r) {
          return r.t + ' [' + r.hyp + '] ' + r.loc + ' :: ' + r.msg + ' :: ' + JSON.stringify(r.data);
        })
        .join('\n');
    }
    var bootRec = {
      t: Date.now(),
      hyp: 'boot',
      loc: 'BaseHead:inline',
      msg: 'boot',
      data: {
        htmlLang: document.documentElement.getAttribute('lang'),
        pathname: location.pathname,
        hasVT: !!document.querySelector('meta[name="astro-view-transitions-enabled"]'),
        scriptOrder: 'inline-script-position',
      },
    };
    append(bootRec);
    // After the rest of <head> has been parsed (including the VT meta), record again.
    function lateBootCheck() {
      append({
        t: Date.now(),
        hyp: 'boot',
        loc: 'BaseHead:DOMContentLoaded',
        msg: 'post-DCL check',
        data: {
          hasVT: !!document.querySelector('meta[name="astro-view-transitions-enabled"]'),
          metaNames: Array.from(document.querySelectorAll('meta[name]')).map(function (m) { return m.getAttribute('name'); }),
        },
      });
      render();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', lateBootCheck, { once: true });
    } else {
      lateBootCheck();
    }
    document.addEventListener(
      'click',
      function (e) {
        var a = e.target && e.target.closest && e.target.closest('a.lang-switch');
        if (!a) return;
        append({
          t: Date.now(),
          hyp: 'A',
          loc: 'BaseHead:click',
          msg: 'lang-switch click',
          data: {
            from: location.pathname,
            to: a.getAttribute('href'),
            htmlLang: document.documentElement.getAttribute('lang'),
            defaultPrevented: e.defaultPrevented,
            metaKey: e.metaKey,
            ctrlKey: e.ctrlKey,
            button: e.button,
            hasReloadAttr: a.hasAttribute('data-astro-reload'),
          },
        });
        render();
      },
      true
    );
    document.addEventListener('astro:before-preparation', function (e) {
      append({
        t: Date.now(),
        hyp: 'A',
        loc: 'BaseHead:astro:before-preparation',
        msg: 'VT before-prep',
        data: {
          from: location.pathname,
          to: e.to && e.to.url ? e.to.url.pathname : null,
          toHref: e.to && e.to.url ? e.to.url.href : null,
          toOrigin: e.to && e.to.url ? e.to.url.origin : null,
          direction: e.direction || null,
          navigationType: e.navigationType || null,
          formData: !!e.formData,
        },
      });
      render();
    });
    document.addEventListener('astro:before-swap', function (e) {
      append({
        t: Date.now(),
        hyp: 'A',
        loc: 'BaseHead:astro:before-swap',
        msg: 'VT before-swap',
        data: {
          from: location.pathname,
          to: e.to && e.to.url ? e.to.url.pathname : null,
          toHref: e.to && e.to.url ? e.to.url.href : null,
          toOrigin: e.to && e.to.url ? e.to.url.origin : null,
          defaultPrevented: e.defaultPrevented,
          newDocHasVT: !!(e.newDocument && e.newDocument.querySelector && e.newDocument.querySelector('meta[name="astro-view-transitions-enabled"]')),
          newDocHtmlLang: e.newDocument && e.newDocument.documentElement ? e.newDocument.documentElement.getAttribute('lang') : null,
        },
      });
      render();
    });
    document.addEventListener('astro:after-swap', function (e) {
      append({
        t: Date.now(),
        hyp: 'A',
        loc: 'BaseHead:astro:after-swap',
        msg: 'VT after-swap',
        data: {
          from: location.pathname,
          to: e.to && e.to.url ? e.to.url.pathname : null,
          newHtmlLang: document.documentElement.getAttribute('lang'),
        },
      });
      render();
    });
    document.addEventListener('astro:after-preparation', function (e) {
      append({
        t: Date.now(),
        hyp: 'A',
        loc: 'BaseHead:astro:after-preparation',
        msg: 'VT after-prep',
        data: {
          from: location.pathname,
          to: e.to && e.to.url ? e.to.url.pathname : null,
          defaultPrevented: e.defaultPrevented,
        },
      });
      render();
    });
    window.addEventListener('pageshow', function (e) {
      append({
        t: Date.now(),
        hyp: 'B',
        loc: 'BaseHead:pageshow',
        msg: 'pageshow',
        data: {
          pathname: location.pathname,
          persisted: e.persisted,
          htmlLang: document.documentElement.getAttribute('lang'),
        },
      });
      render();
    });
    window.addEventListener('beforeunload', function () {
      append({
        t: Date.now(),
        hyp: 'B',
        loc: 'BaseHead:beforeunload',
        msg: 'beforeunload',
        data: {
          pathname: location.pathname,
          htmlLang: document.documentElement.getAttribute('lang'),
        },
      });
    });
  })();
</script>
<!-- #endregion agent log -->
