---
const currentYear = new Date().getFullYear();
const githubHref = 'https://github.com/otto666357';
const lang: 'en' | 'zh' = Astro.url.pathname.startsWith('/en') ? 'en' : 'zh';
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <span>&copy; {currentYear} otto666357. All rights reserved.</span>
    <span>
      <a href={githubHref} rel="noopener" target="_blank">GitHub</a>
      &middot;
      <a href={`/${lang}/rss.xml`}>RSS</a>
    </span>
  </div>
</footer>
