---
import { getAlternateLanguage, type Language } from '~/i18n/utils';
import { languages } from '~/i18n/ui';

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const altLang = getAlternateLanguage(currentLang);
// Strip an existing /zh or /en prefix and always prepend /:altLang so we never
// emit the bare "/" path. The bare "/" URL is reserved by the SSR redirect
// (src/pages/index.astro) which is served as a meta-refresh HTML page on
// GitHub Pages; that page lacks the Astro view-transitions meta tag, so the
// view-transition router would fail to swap and fall back to a hard reload.
const stripped = Astro.url.pathname.replace(/^\/(zh|en)(?=\/|$)/, '') || '/';
const tail = stripped === '/' ? '/' : `${stripped.startsWith('/') ? '' : '/'}${stripped}`;
const altPath = `/${altLang}${tail}`;
const altLabel = languages[altLang];
---
<a
  href={altPath}
  class="lang-switch"
  aria-label={`Switch language to ${altLabel}`}
  title={`Switch language to ${altLabel}`}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M2 12h20"></path>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
  </svg>
  <span>{altLabel}</span>
</a>
