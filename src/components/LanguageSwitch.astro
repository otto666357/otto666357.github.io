---
import { getAlternateLanguage, getLocalizedPath, type Language } from '~/i18n/utils';
import { languages } from '~/i18n/ui';

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const altLang = getAlternateLanguage(currentLang);
const altPath = getLocalizedPath(Astro.url.pathname, altLang);
const altLabel = languages[altLang];
---
<a
  href={altPath}
  class="lang-switch"
  aria-label={`Switch language to ${altLabel}`}
  title={`Switch language to ${altLabel}`}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="10"></circle>
    <path d="M2 12h20"></path>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
  </svg>
  <span>{altLabel}</span>
</a>
