---
import { getLangFromUrl, type Language } from '~/i18n/utils';

interface Props {
  repo: string;
  repoId: string;
  category: string;
  categoryId: string;
}

const { repo, repoId, category, categoryId } = Astro.props;
const lang: Language = getLangFromUrl(Astro.url);
---
<section class="comments" id="comments">
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang={lang}
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
  <noscript>
    <p>Comments require JavaScript.</p>
  </noscript>
</section>
