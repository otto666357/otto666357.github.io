---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { type Language } from '~/i18n/utils';

const lang: Language = 'en';
---
<BaseLayout title="About" description="About me">
  <header class="page-header">
    <h1 class="page-header__title">About</h1>
  </header>

  <div class="prose">
    <p>
      Welcome to my personal blog. I write about ideas in technology, reading, and life.
    </p>
    <p>
      This site is built with <a href="https://astro.build" rel="noopener" target="_blank">Astro</a>,
      supports bilingual content (English &amp; Chinese), and is deployed automatically to GitHub Pages.
    </p>

    <h2>Writing principles</h2>
    <ul>
      <li>Write until you can fully explain an idea to yourself</li>
      <li>Prefer explaining "why" over "how"</li>
      <li>Code samples should be runnable, not fragments</li>
    </ul>

    <h2>Get in touch</h2>
    <ul>
      <li>GitHub: <a href="https://github.com/otto666357" rel="noopener" target="_blank">@otto666357</a></li>
      <li>Email: <a href="mailto:hello@example.com">hello@example.com</a></li>
    </ul>
  </div>
</BaseLayout>
