---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getLangFromUrl, defaultLanguage, getLocalizedPath, type Language } from '~/i18n/utils';
import { t } from '~/i18n/ui';

const lang: Language = getLangFromUrl(Astro.url);
const homeHref = lang === defaultLanguage ? '/' : `/${lang}/`;
---
<BaseLayout title={t('notfound.title', lang)} description={t('notfound.description', lang)}>
  <div class="notfound">
    <h1 class="notfound__code">404</h1>
    <h2 class="notfound__title">{t('notfound.title', lang)}</h2>
    <p class="notfound__description">{t('notfound.description', lang)}</p>
    <a class="nav-link" href={homeHref}>&larr; {t('notfound.back', lang)}</a>
  </div>
</BaseLayout>
