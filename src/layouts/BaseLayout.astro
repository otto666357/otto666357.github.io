---
import '~/styles/global.css';
import BaseHead from '~/components/BaseHead.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import { getLangFromUrl, type Language } from '~/i18n/utils';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, image, type, pubDate, updatedDate, tags } = Astro.props;
const lang: Language = getLangFromUrl(Astro.url);
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en-US';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      pubDate={pubDate}
      updatedDate={updatedDate}
      tags={tags}
    />
    <ViewTransitions />
  </head>
  <body>
    <Header />
    <main class="site-content">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
